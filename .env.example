# Supabase PostgreSQL connection string (pooled via Supavisor, port 6543)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Simple credentials auth (single-user)
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
